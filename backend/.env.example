# Server
PORT=4000
NODE_ENV=development

# MongoDB
# Local dev (no MongoDB install needed): run `npm run db` in backend/, it starts a replica set at this URI
# Production: replace with your MongoDB Atlas connection string
MONGODB_URI=mongodb://127.0.0.1:27117/zaraz-dev?replicaSet=rs0

# JWT
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# Email (leave blank in local dev -> emails are logged to console instead of sent)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Cloudinary (leave blank in local dev -> uploads fall back to local disk at backend/uploads/,
# which is fine for local testing but does NOT survive a redeploy/restart on most hosts.
# Set all three in production so uploaded photos/receipts persist. Free tier at cloudinary.com.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Google Sheets offline-fallback sync (leave blank -> sync job silently no-ops).
# Create a Google Cloud service account with the Sheets API and Drive API enabled,
# then paste its client_email and private_key here (keep the \n escapes in the key).
GOOGLE_SHEETS_CLIENT_EMAIL=
GOOGLE_SHEETS_PRIVATE_KEY=

# Platform
ALLOWED_ORIGIN=http://localhost:3000
COMMISSION_PLATFORM=0.02
COMMISSION_MANUAL=0.01
SUPER_ADMIN_EMAIL=admin@zaraz.ua
